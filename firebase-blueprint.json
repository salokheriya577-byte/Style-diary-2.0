{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "createdAt"]
    },
    "Item": {
      "title": "Item",
      "description": "Wardrobe item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "weatherTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "imageUrl", "weatherTags", "userId", "createdAt"]
    },
    "Outfit": {
      "title": "Outfit",
      "description": "Combined outfit",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "itemIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "itemIds", "userId", "createdAt"]
    },
    "Log": {
      "title": "Log",
      "description": "Chronicle log entry",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "outfitId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "outfitId", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/users/{userId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/Item" },
      "description": "User wardrobe items"
    },
    "/users/{userId}/outfits/{outfitId}": {
      "schema": { "$ref": "#/entities/Outfit" },
      "description": "User styled outfits"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": { "$ref": "#/entities/Log" },
      "description": "User chronicle logs"
    }
  }
}
